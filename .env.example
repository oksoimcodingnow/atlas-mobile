# Copy this file to .env.local and fill in your real keys.
# .env.local is gitignored — your keys never reach GitHub.

# === AI PROVIDERS (at least one required) ===

# Ollama local mode - no cloud API key, no credits.
# Install Ollama, then run: ollama pull llama3.2:3b
# This works from local dev only. Vercel cannot reach Ollama on your laptop.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Google Gemini API key — FREE TIER available (1500 requests/day)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Groq API key — FREE TIER (30 RPM, 14,400 RPD on Llama 3.3 70B)
# Blazing fast (~500 tokens/sec), supports tool use
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Anthropic API key — pay-per-token (separate billing from Claude.ai subscription)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# === GITHUB (required) ===

# GitHub Personal Access Token with `repo` scope
# Generate at: https://github.com/settings/tokens/new
GITHUB_TOKEN=ghp_...

# Your GitHub username (so ATLAS knows whose repos to touch by default)
GITHUB_USER=oksoimcodingnow

# === WEB PUSH NOTIFICATIONS (required for phone alerts) ===

# Generated once via: npx web-push generate-vapid-keys
# Public key goes to browser, private key signs pushes server-side
VAPID_PUBLIC_KEY=BCyScOYb6b8zof0uASiGGit3hzOid-h0ZDcwoJqeSFxwppC2Hyiaz4jRuve9CSas4cf0_rIao-cHH6DU1whs7P0
VAPID_PRIVATE_KEY=HQ_Nt4fjwJ5mWHb_No8QtGoB8EbqlBLZ3PY9mwEsf9I
VAPID_SUBJECT=mailto:hzdjdndb@gmail.com

# === REMINDERS + CRON (needed for scheduled push notifications) ===

# Vercel KV (Upstash Redis) — auto-injected when you connect a KV database
# in the Vercel Storage tab. You DON'T need to paste these manually if you
# use Vercel; they appear automatically. For local dev, copy from Vercel's
# "Pull env vars" command.
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your-kv-token

# Shared secret for /api/cron/tick. Add the same value as a GitHub repo
# secret named CRON_SECRET so the Action can authenticate.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-with-a-random-hex-string
